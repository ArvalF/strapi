{
  "kind": "collectionType",
  "collectionName": "presses",
  "info": {
    "singularName": "press",
    "pluralName": "presses",
    "displayName": "Press"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "logo_magazine": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "publication": {
      "type": "date"
    },
    "pdf_article": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "couverture_magazine": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "link": {
      "type": "string",
      "regex": "https://.*"
    },
    "printed": {
      "type": "boolean",
      "required": true
    },
    "title": {
      "type": "string"
    }
  }
}
