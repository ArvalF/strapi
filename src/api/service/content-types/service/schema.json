{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "url": {
      "type": "string",
      "required": true,
      "regex": "^[a-zA-Z0-9]+(?:-[a-zA-Z0-9]+)*$"
    },
    "menuTitle": {
      "type": "string",
      "required": true
    },
    "titre": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "service_types": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::service-type.service-type",
      "mappedBy": "services"
    },
    "scrollable": {
      "type": "dynamiczone",
      "components": [
        "shared.slider",
        "shared.rich-text",
        "shared.media",
        "my-components.before-after-visualizer"
      ]
    }
  }
}
